<div xmlns:tal="http://xml.zope.org/namespaces/tal"
     class="block slateTable"
     tal:condition="view/has_rows">
  <div class="table-scroll-container">
    <table tal:attributes="class string:table ${view/table_classes}">
      <thead tal:condition="not:view/hide_headers">
        <tr>
          <th scope="col"
              tal:repeat="cell view/header_cells"
              tal:content="structure python:view.cell_html(cell)">cell</th>
        </tr>
      </thead>
      <tbody>
        <tr tal:repeat="row view/data_rows">
          <td tal:repeat="cell row/cells"
              tal:content="structure python:view.cell_html(cell)">cell</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
