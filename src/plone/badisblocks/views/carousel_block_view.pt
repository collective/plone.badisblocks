<div xmlns:tal="http://xml.zope.org/namespaces/tal"
     tal:attributes="class view/css_class"
     tal:define="count view/column_count">
  <h2 class="headline"
      tal:condition="view/headline"
      tal:content="view/headline">Carousel</h2>
  <div class="carousel-wrapper"
       tal:condition="count"
       tal:attributes="style view/track_style">
    <button class="carousel-button carousel-button-prev"
            type="button"
            aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 36"
           class="icon" aria-hidden="true">
        <path fill-rule="evenodd"
              d="M21.293 9.293 22.707 10.707 15.414 18 22.707 25.293 21.293 26.707 12.586 18z" />
      </svg>
    </button>
    <button class="carousel-button carousel-button-next"
            type="button"
            aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 36"
           class="icon" aria-hidden="true">
        <path fill-rule="evenodd"
              d="M14.707 26.707 13.293 25.293 20.586 18 13.293 10.707 14.707 9.293 23.414 18z" />
      </svg>
    </button>
    <div class="carousel-viewport">
      <div class="carousel-container">
        <div class="carousel-slide"
             tal:repeat="column view/columns"
             tal:content="structure column">column</div>
      </div>
    </div>
    <div class="carousel-dots">
      <button class="carousel-dot"
              type="button"
              tal:repeat="n python:range(count)"
              tal:attributes="aria-label python:'Go to slide %d' % (n + 1)"></button>
    </div>
  </div>
</div>
