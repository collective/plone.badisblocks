<div xmlns:tal="http://xml.zope.org/namespaces/tal"
     tal:attributes="class view/css_class">
  <a class="skip-map-link"
     tal:attributes="href string:#${view/anchor_id}">Skip map</a>

  <div class="maps-wrapper"
       role="region"
       tal:attributes="aria-label view/aria_label">
    <iframe loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen="allowfullscreen"
            frameborder="0"
            tal:condition="view/url"
            tal:attributes="src view/url; title view/title"></iframe>
  </div>

  <noscript tal:condition="view/url">
    <p>View <a tal:attributes="href view/url"
               tal:content="view/aria_label">this location</a> on Google Maps</p>
  </noscript>

  <span tal:attributes="id view/anchor_id"></span>
</div>
