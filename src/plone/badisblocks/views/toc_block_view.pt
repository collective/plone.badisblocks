<nav xmlns:tal="http://xml.zope.org/namespaces/tal"
     class="block toc"
     tal:attributes="aria-label view/aria_label">
  <h2 class="toc-title"
      tal:condition="view/show_title"
      tal:content="view/title">title</h2>

  <p class="toc-empty"
     tal:condition="not:view/entries">No headings found on this page.</p>

  <tal:list tal:condition="view/entries"
            tal:define="ordered view/ordered">
    <ol class="toc-list" tal:condition="ordered">
      <li tal:repeat="entry view/entries"
          tal:attributes="class string:toc-item toc-level-${entry/level}">
        <a class="toc-link"
           tal:attributes="href string:#${entry/id}"
           tal:content="entry/title">heading</a>
      </li>
    </ol>
    <ul class="toc-list" tal:condition="not:ordered">
      <li tal:repeat="entry view/entries"
          tal:attributes="class string:toc-item toc-level-${entry/level}">
        <a class="toc-link"
           tal:attributes="href string:#${entry/id}"
           tal:content="entry/title">heading</a>
      </li>
    </ul>
  </tal:list>
</nav>
