<div xmlns:tal="http://xml.zope.org/namespaces/tal"
     tal:attributes="class view/css_class">

  <tal:headline tal:condition="view/headline">
    <h2 class="headline"
        tal:condition="python:view.headline_tag == 'h2'"
        tal:content="view/headline">headline</h2>
    <h3 class="headline"
        tal:condition="python:view.headline_tag == 'h3'"
        tal:content="view/headline">headline</h3>
  </tal:headline>

  <p class="listing-empty"
     tal:condition="not:view/items">No results found.</p>

  <ul class="items"
      tal:condition="view/items">
    <li tal:repeat="item view/items"
        tal:attributes="class python:view.item_class(item)">
      <div class="card">
        <div class="card-inner">
          <div class="image-wrapper"
               tal:condition="python:view.show_image and item['image']">
            <img class="responsive"
                 loading="lazy"
                 tal:attributes="src item/image/src;
                                srcset item/image/srcset;
                                sizes item/image/sizes;
                                width item/image/width;
                                height item/image/height;
                                alt item/image/alt" />
          </div>
          <div class="card-summary">
            <div class="headline"
                 tal:condition="item/head_title"
                 tal:content="item/head_title">head title</div>
            <div class="title">
              <a class="card-primary-link"
                 tal:attributes="href item/url"
                 tal:content="item/title">title</a>
            </div>
            <p class="description"
               tal:condition="item/description"
               tal:content="item/description">description</p>
          </div>
        </div>
      </div>
    </li>
  </ul>

  <div class="footer"
       tal:condition="view/show_link_more">
    <a tal:attributes="href view/link_more_href"
       tal:content="view/link_more_title">more</a>
  </div>
</div>
