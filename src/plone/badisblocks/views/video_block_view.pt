<div xmlns:tal="http://xml.zope.org/namespaces/tal"
     tal:attributes="class view/css_class">
  <div class="video-wrapper"
       tal:condition="view/embed_url">
    <iframe frameborder="0"
            allowfullscreen="allowfullscreen"
            tal:attributes="src view/embed_url;
                            title view/iframe_title;
                            allow view/iframe_allow"></iframe>
  </div>
  <div class="video-wrapper"
       tal:condition="view/video_src">
    <video controls="controls"
           tal:attributes="src view/video_src; poster view/poster"></video>
  </div>
</div>
